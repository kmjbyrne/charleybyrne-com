#!/usr/bin/env bash
set -euo pipefail

STACK_NAME="CharleyByrneSiteStack"
REGION="eu-west-1"

echo "==> Building site..."
npm run generate

echo "==> Looking up stack outputs..."
BUCKET_NAME=$(aws cloudformation describe-stacks \
  --stack-name "$STACK_NAME" \
  --region "$REGION" \
  --query "Stacks[0].Outputs[?OutputKey=='BucketName'].OutputValue" \
  --output text)

DIST_ID=$(aws cloudformation describe-stacks \
  --stack-name "$STACK_NAME" \
  --region "$REGION" \
  --query "Stacks[0].Outputs[?OutputKey=='DistributionId'].OutputValue" \
  --output text)

echo "==> Bucket: $BUCKET_NAME"
echo "==> Distribution: $DIST_ID"

# Staged sync closes the mid-deploy window where cached HTML references
# assets that are not uploaded yet (or already deleted). Hashed assets land
# first with immutable caching, HTML and payloads switch over second with
# no-cache so browsers always revalidate, and stale files are pruned last.
echo "==> Syncing hashed assets (immutable)..."
aws s3 sync .output/public "s3://$BUCKET_NAME" \
  --exclude "*.html" \
  --exclude "*_payload.json" \
  --cache-control "public,max-age=31536000,immutable"

echo "==> Syncing HTML and payloads (no-cache)..."
aws s3 sync .output/public "s3://$BUCKET_NAME" \
  --exclude "*" \
  --include "*.html" \
  --include "*_payload.json" \
  --cache-control "no-cache"

echo "==> Pruning removed files..."
aws s3 sync .output/public "s3://$BUCKET_NAME" --delete

echo "==> Invalidating CloudFront..."
aws cloudfront create-invalidation \
  --distribution-id "$DIST_ID" \
  --paths "/*" \
  --query "Invalidation.Id" \
  --output text

echo "==> Done."
